# Application
APP_BASE_URL=http://localhost:8080
NODE_ENV=development
# Maintenance (redirige vers /maintenance ; les webhooks /api/* restent actifs)
# MAINTENANCE_MODE=true
# VITE_MAINTENANCE_MODE=true
# Production Vercel : DEMO_MODE=false, APP_BASE_URL=https://miss-jg.vercel.app
DEMO_MODE=true
VITE_DEMO_MODE=true

# Easy Transact — https://api.easy-transact.net/api/v1/partner/transactions/initiate/
EASYTRANSACT_API_URL=https://api.easy-transact.net
# Clé API (Bearer) — dashboard → Clés API → sk_live_…
EASYTRANSACT_API_TOKEN=
# Service CASH_IN (encaissement Mobile Money Cameroun)
EASYTRANSACT_SERVICE_CODE=CASH_IN
EASYTRANSACT_COUNTRY_CODE=CM
# Réseaux (défaut : ORANGE_CM / MTN_CM — pas besoin de les changer sauf instruction Easy Transact)
# EASYTRANSACT_NETWORK_ORANGE=ORANGE_CM
# EASYTRANSACT_NETWORK_MTN=MTN_CM
# Numéro marchand de réception (optionnel ; sinon = numéro du votant)
# EASYTRANSACT_RECEIVER_NUMBER=

# Dashboard Easy Transact → Profil → Webhook (URLs HTTPS, pas de secret requis) :
#   https://miss-jg.vercel.app/api/public/payments/webhook
#   success → https://miss-jg.vercel.app/vote/success
#   échec  → https://miss-jg.vercel.app/vote/echec
