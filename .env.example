# Application
APP_BASE_URL=http://localhost:8080
NODE_ENV=development
# Production Vercel : DEMO_MODE=false, APP_BASE_URL=https://miss-jg.vercel.app
DEMO_MODE=true
VITE_DEMO_MODE=true

# Easy Transact — dashboard partenaire Miss JG (https://api.easy-transact.net/api/v1/)
EASYTRANSACT_API_URL=https://api.easy-transact.net
# Clés API → sk_live_… (obligatoire en production)
EASYTRANSACT_API_TOKEN=
EASYTRANSACT_SERVICE_CODE=DEPOSIT
# operator_id : lancer « npm run et:operators » avec le token ci-dessus pour les afficher
EASYTRANSACT_OPERATOR_ORANGE=
EASYTRANSACT_OPERATOR_MTN=
# EASYTRANSACT_OPERATORS={"orange":"<id>","mtn":"<id>"}

# Secret HMAC webhook (PAS l’URL du webhook — uniquement la clé secrète Easy Transact)
PAYMENT_WEBHOOK_SECRET=

# Dashboard Easy Transact → Profil → Configuration Webhook (HTTPS obligatoire en prod) :
#   webhook_url          → {APP_BASE_URL}/api/public/payments/webhook
#   success_callback_url → {APP_BASE_URL}/vote/success  (ou URL de votre domaine)
#   failure_callback_url → {APP_BASE_URL}/vote/echec
# Whitelist IP : ajouter l'IP publique de votre serveur (sinon les appels API peuvent être refusés)
